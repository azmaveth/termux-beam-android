<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/config_title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#333333" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/config_subtitle"
            android:textSize="12sp"
            android:textColor="#888888" />

        <!-- Distributed toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/config_distributed"
                android:textSize="16sp"
                android:textColor="#333333" />

            <Switch
                android:id="@+id/config_distributed_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/config_distributed_hint"
            android:textSize="11sp"
            android:textColor="#888888" />

        <!-- Node name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/config_node_name"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#555555" />

        <EditText
            android:id="@+id/config_node_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textNoSuggestions"
            android:fontFamily="monospace"
            android:hint="name@host"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/config_node_name_hint"
            android:textSize="11sp"
            android:textColor="#888888" />

        <!-- Cluster nodes -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/config_cluster_nodes"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#555555" />

        <EditText
            android:id="@+id/config_cluster_nodes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine|textNoSuggestions"
            android:fontFamily="monospace"
            android:minLines="2"
            android:gravity="top"
            android:hint="peer1@host, peer2@host"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/config_cluster_nodes_hint"
            android:textSize="11sp"
            android:textColor="#888888" />

        <!-- Cookie -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/config_cookie"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#555555" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/config_cookie"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="textPassword"
                android:fontFamily="monospace"
                android:textSize="14sp" />

            <Button
                android:id="@+id/config_cookie_show"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="@string/config_show"
                android:textSize="11sp"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
        </LinearLayout>

        <Button
            android:id="@+id/config_cookie_generate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/config_generate_cookie"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/config_cookie_hint"
            android:textSize="11sp"
            android:textColor="#888888" />

        <!-- Speech Recognition -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:background="#DDDDDD" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Speech Recognition"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#333333" />

        <!-- ASR Mode toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Remote ASR (GPU)"
                android:textSize="16sp"
                android:textColor="#333333" />

            <Switch
                android:id="@+id/config_asr_remote_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="When enabled, speech is sent to a GPU node in the cluster for transcription. Faster and more accurate, but requires network connectivity."
            android:textSize="11sp"
            android:textColor="#888888" />

        <!-- Remote ASR Node -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Remote ASR Node"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#555555" />

        <EditText
            android:id="@+id/config_remote_asr_node"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textNoSuggestions"
            android:fontFamily="monospace"
            android:hint="arbor_gpu2@10.42.42.97"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BEAM node name of the GPU server running the ASR service. Must be reachable from the cluster."
            android:textSize="11sp"
            android:textColor="#888888" />

        <!-- Custom Dictionary -->
        <Button
            android:id="@+id/config_dictionary_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Custom Dictionary..."
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add custom words (names, places, terms) the recognizer should know."
            android:textSize="11sp"
            android:textColor="#888888" />

        <!-- Save / Cancel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/config_cancel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="@string/config_cancel" />

            <Button
                android:id="@+id/config_save"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="@string/config_save" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/config_restart_hint"
            android:textSize="11sp"
            android:textColor="#888888"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>
